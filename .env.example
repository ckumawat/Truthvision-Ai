# Environment Configuration
# Copy this file to .env and fill in your values

# Server Configuration
NODE_ENV=production
PORT=3002
HOST=0.0.0.0

# Database Configuration
DB_HOST=localhost
DB_TYPE=mysql
DB_USER=root
DB_PASSWORD=
DB_NAME=truthvision
DB_PORT=3306

# Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=52428800

# API Configuration
API_TIMEOUT=30000
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info
